# Site URL (used for canonical, sitemap, robots, Open Graph)
NEXT_PUBLIC_SITE_URL=https://solentrahouse.xyz

# Contact form destination
CONTACT_TO_EMAIL=support@solentrahouse.xyz
RESEND_API_KEY=your_resend_api_key_here

# Cloudflare Turnstile (captcha)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your_turnstile_site_key_here
TURNSTILE_SECRET_KEY=your_turnstile_secret_key_here

# Analytics
NEXT_PUBLIC_GA_ID=your_ga4_id_here
NEXT_PUBLIC_CLARITY_PROJECT_ID=your_clarity_project_id_here

# Supabase (auth + database)
NEXT_PUBLIC_SUPABASE_URL=https://eczsdmdulyntnspmwvdi.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Gumroad payment URLs (one per Gumroad-sold service)
NEXT_PUBLIC_GUMROAD_SOLENTRA_SCAN_URL=https://gumroad.com/l/your_product_link
NEXT_PUBLIC_GUMROAD_PERFORMANCE_OPTIMISATION_URL=https://gumroad.com/l/your_product_link
NEXT_PUBLIC_GUMROAD_BRAND_COMMUNICATIONS_URL=https://gumroad.com/l/your_product_link
NEXT_PUBLIC_GUMROAD_DIGITAL_STRATEGY_URL=https://gumroad.com/l/your_product_link
NEXT_PUBLIC_GUMROAD_COMMUNICATIONS_PLANNING_URL=https://gumroad.com/l/your_product_link
NEXT_PUBLIC_GUMROAD_ACQUISITION_FUNNEL_URL=https://gumroad.com/l/your_product_link
NEXT_PUBLIC_GUMROAD_CAMPAIGN_LAUNCH_URL=https://gumroad.com/l/your_product_link
NEXT_PUBLIC_GUMROAD_SOLENTRA_GROWTH_URL=https://gumroad.com/l/your_product_link

# Gumroad webhook (optional — for recording purchases in account dashboard)
GUMROAD_WEBHOOK_SECRET=your_gumroad_webhook_secret_here
GUMROAD_ACCESS_TOKEN=your_gumroad_access_token_here
